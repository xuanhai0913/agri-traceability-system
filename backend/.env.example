# ========================================
# Backend Environment Variables
# ========================================

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL producer store
DATABASE_URL=
DATABASE_SSL=false

# Admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NAME=AgriTrace Admin
JWT_SECRET=change_this_long_random_secret
# Demo role accounts are seeded automatically outside production.
# Set true on a demo server only when you want producer/inspector/warehouse/distributor demo accounts.
SEED_DEMO_USERS=false
# Demo producer profiles are disabled in production unless explicitly enabled.
# Keep this false on production after cleaning unrelated seed/mock producers.
SEED_DEMO_PRODUCERS=false

# Blockchain
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=your_private_key_here
CONTRACT_ADDRESS=your_contract_address_here
CONTRACT_STAGE_SCHEMA=v2
CHAIN_ID=80002
NETWORK_NAME=Polygon Amoy
EXPLORER_BASE_URL=https://amoy.polygonscan.com
SOURCIFY_BASE_URL=https://repo.sourcify.dev
# Set false only when pointing CONTRACT_ADDRESS to a newly deployed, unverified contract.
SOURCIFY_VERIFIED=true

# Evidence storage: Pinata/IPFS
# PINATA_JWT chỉ đặt ở backend Render/local server, không đưa lên frontend.
IPFS_PROVIDER=pinata
IPFS_ENABLED=true
IPFS_REQUIRED=false
PINATA_JWT=your_pinata_jwt
IPFS_GATEWAY=https://your-gateway.mypinata.cloud/ipfs/

# Unsplash media picker
# Use the public Access Key only. Secret Key is not required by AgriTrace.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
