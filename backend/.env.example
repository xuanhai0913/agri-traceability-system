# ========================================
# Backend Environment Variables
# ========================================

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL producer store
DATABASE_URL=
DATABASE_SSL=false

# Admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password
ADMIN_NAME=AgriTrace Admin
JWT_SECRET=change_this_long_random_secret

# Blockchain
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=your_private_key_here
CONTRACT_ADDRESS=your_contract_address_here
CHAIN_ID=80002
NETWORK_NAME=Polygon Amoy
EXPLORER_BASE_URL=https://amoy.polygonscan.com
SOURCIFY_BASE_URL=https://repo.sourcify.dev

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
